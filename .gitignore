# =============================================================================
# .gitignore — Nifty 100 Financial Analytics Platform
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Raw data (large Excel files — do not commit) ──────────────────────────────
data/raw/*.xlsx
data/raw/*.xls
data/raw/*.csv
data/processed/

# ── Generated outputs ─────────────────────────────────────────────────────────
output/
*.pdf
*.pptx

# ── Environment ───────────────────────────────────────────────────────────────
.env
*.env

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Notebooks checkpoints ─────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Zip artefacts ─────────────────────────────────────────────────────────────
*.zip
